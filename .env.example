# Copy this file to .env and replace placeholder values.
# PowerShell:
#   copy .env.example .env

# MongoDB
MONGO_URI=mongodb://localhost:27017/
MONGO_DB=news_summarizer

# Gemini API
# Create a key from Google AI Studio and paste it here.
GEMINI_API_KEY=your_gemini_api_key_here

# Optional Gemini model controls.
# The fallback model is used when the primary model returns temporary 503 high-demand errors.
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.0-flash

# Backward-compatible key name used by older scripts.
GEMINI_KEY=

# Optional, used by fake-news/game scripts if enabled.
GROQ_API_KEY=
